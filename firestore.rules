rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net (default deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Validations
    function isValidUserProfile(data) {
      return (
        data.keys().hasAll(['gender', 'race']) &&
        data.gender in ['male', 'female'] &&
        data.race in ['white', 'african_american', 'other'] &&
        (!data.keys().hasAny(['age']) || (data.age is int && data.age >= 10 && data.age <= 120)) &&
        (!data.keys().hasAny(['systolicBp']) || (data.systolicBp is int && data.systolicBp >= 50 && data.systolicBp <= 300)) &&
        (!data.keys().hasAny(['treatedForHypertension']) || data.treatedForHypertension is bool) &&
        (!data.keys().hasAny(['diabetes']) || data.diabetes is bool) &&
        (!data.keys().hasAny(['smoker']) || data.smoker is bool)
      );
    }

    function isValidCholesterolLog(data) {
      return (
        data.keys().hasAll(['date', 'totalChol', 'hdl', 'ldl', 'triglycerides']) &&
        data.date is string &&
        data.totalChol is int && data.totalChol > 0 && data.totalChol <= 1000 &&
        data.hdl is int && data.hdl >= 0 && data.hdl <= 250 &&
        data.ldl is int && data.ldl >= 0 && data.ldl <= 800 &&
        data.triglycerides is int && data.triglycerides > 0 && data.triglycerides <= 2000
      );
    }

    function isValidLifestyleLog(data) {
      return (
        data.keys().hasAll(['date', 'foodDescription', 'satFat', 'solubleFiber', 'activityType', 'duration', 'mets', 'supplements', 'weight', 'bodyWater', 'activeCalories', 'restingHr']) &&
        data.date is string &&
        data.foodDescription is string &&
        (data.satFat is int || data.satFat is float) && data.satFat >= 0 &&
        (data.solubleFiber is int || data.solubleFiber is float) && data.solubleFiber >= 0 &&
        data.activityType in ['cardio', 'strength', 'hiit', 'yoga', 'other'] &&
        data.duration is int && data.duration > 0 &&
        (data.mets is int || data.mets is float) && data.mets >= 0 &&
        data.supplements is list &&
        (data.weight is int || data.weight is float) && data.weight >= 0 &&
        (data.bodyWater is int || data.bodyWater is float) && data.bodyWater >= 0 &&
        data.activeCalories is int && data.activeCalories >= 0 &&
        data.restingHr is int && data.restingHr >= 0
      );
    }

    // Collection: User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && isValidUserProfile(incoming());
      allow delete: if isOwner(userId);

      // Sub-collection: Cholesterol Logs
      match /logs/{logId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(userId) && isValidId(logId) && isValidCholesterolLog(incoming());
        allow update: if isOwner(userId) && isValidCholesterolLog(incoming());
        allow delete: if isOwner(userId);
      }

      // Sub-collection: Lifestyle Logs
      match /lifestyle/{lifestyleId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(userId) && isValidId(lifestyleId) && isValidLifestyleLog(incoming());
        allow update: if isOwner(userId) && isValidLifestyleLog(incoming());
        allow delete: if isOwner(userId);
      }
    }
  }
}
